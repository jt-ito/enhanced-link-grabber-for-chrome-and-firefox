{
  "manifest_version": 3,
  "name": "Link Grabber for Chrome",
  "version": "1.4",
  "description": "Extract and copy links from any webpage.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/contentscript.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon_48.png",
      "96": "icon_96.png",
      "128": "icon_128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon_48.png",
    "96": "icon_96.png",
    "128": "icon_128.png"
  }
}
