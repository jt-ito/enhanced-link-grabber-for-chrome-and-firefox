{
  "manifest_version": 2,
  "name": "Link Grabber for Firefox",
  "version": "1.3.2",
  "description": "Extract and copy links from any webpage.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/contentscript.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icon_48.png"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "icons": {
    "48": "icon_48.png",
    "96": "icon_96.png",
    "128": "icon_128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "8bba29b7afda4922af56",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}